{
  "name": "gesa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "migrate:supabase:tasks": "node scripts/migrate-firebase-to-supabase.js tasks",
    "migrate:supabase:tasks:dry-run": "node scripts/migrate-firebase-to-supabase.js tasks --dry-run",
    "migrate:supabase:reports": "node scripts/migrate-firebase-to-supabase.js reports",
    "migrate:supabase:reports:dry-run": "node scripts/migrate-firebase-to-supabase.js reports --dry-run",
    "migrate:supabase:survey-existing": "node scripts/migrate-firebase-to-supabase.js survey-existing",
    "migrate:supabase:survey-existing:dry-run": "node scripts/migrate-firebase-to-supabase.js survey-existing --dry-run",
    "migrate:supabase:survey-apj-propose": "node scripts/migrate-firebase-to-supabase.js survey-apj-propose",
    "migrate:supabase:survey-apj-propose:dry-run": "node scripts/migrate-firebase-to-supabase.js survey-apj-propose --dry-run",
    "migrate:supabase:survey-pra-existing": "node scripts/migrate-firebase-to-supabase.js survey-pra-existing",
    "migrate:supabase:survey-pra-existing:dry-run": "node scripts/migrate-firebase-to-supabase.js survey-pra-existing --dry-run",
    "migrate:supabase:user-admin": "node scripts/migrate-firebase-to-supabase.js user-admin",
    "migrate:supabase:user-admin:dry-run": "node scripts/migrate-firebase-to-supabase.js user-admin --dry-run",
    "migrate:supabase:tracking-sessions": "node scripts/migrate-firebase-to-supabase.js tracking-sessions",
    "migrate:supabase:tracking-sessions:dry-run": "node scripts/migrate-firebase-to-supabase.js tracking-sessions --dry-run",
    "sync:supabase:once": "node scripts/sync-firebase-to-supabase-once.js",
    "sync:supabase:once:survey-work": "set SYNC_PROFILE=survey-work&& node scripts/sync-firebase-to-supabase-once.js",
    "sync:supabase:once:backoffice": "set SYNC_PROFILE=backoffice&& node scripts/sync-firebase-to-supabase-once.js",
    "sync:supabase:cloud-server": "node scripts/cloud-run-sync-server.js",
    "sync:supabase:scheduler": "node scripts/sync-firebase-to-supabase-scheduler.js",
    "sync:supabase:deploy-cloud": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloud-sync.ps1",
    "sync:supabase:register-task": "powershell -ExecutionPolicy Bypass -File scripts/register-supabase-sync-task.ps1",
    "sync:supabase:unregister-task": "powershell -ExecutionPolicy Bypass -File scripts/unregister-supabase-sync-task.ps1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "@types/leaflet": "^1.9.21",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.8.0",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "next": "^16.1.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-leaflet": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.6",
    "tailwindcss": "^4",
    "typescript": "^5"
